{
  "name": "foxxycode-vscode",
  "displayName": "%ext.displayName%",
  "description": "%ext.description%",
  "version": "0.1.6",
  "publisher": "foxxycode",
  "license": "MIT",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Machine Learning",
    "Other"
  ],
  "main": "./out/extension.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/hijera/foxxy-agent.git",
    "directory": "editors/vscode"
  },
  "homepage": "https://github.com/hijera/foxxy-agent/tree/main/editors/vscode#readme",
  "bugs": {
    "url": "https://github.com/hijera/foxxy-agent/issues"
  },
  "activationEvents": [
    "onView:foxxycode.view",
    "onCommand:foxxycode.openPanel",
    "onCommand:foxxycode.openPanel.ru",
    "onCommand:foxxycode.showWelcome"
  ],
  "contributes": {
    "commands": [
      {
        "command": "foxxycode.openPanel",
        "title": "%cmd.openPanel.title%",
        "category": "FoxxyCode"
      },
      {
        "command": "foxxycode.openPanel.ru",
        "title": "%cmd.openPanel.title.ru%",
        "category": "FoxxyCode"
      },
      {
        "command": "foxxycode.restart",
        "title": "%cmd.restart.title%",
        "category": "FoxxyCode",
        "icon": "$(refresh)"
      },
      {
        "command": "foxxycode.restart.ru",
        "title": "%cmd.restart.title.ru%",
        "category": "FoxxyCode",
        "icon": "$(refresh)"
      },
      {
        "command": "foxxycode.reload",
        "title": "%cmd.reload.title%",
        "category": "FoxxyCode",
        "icon": "$(sync)"
      },
      {
        "command": "foxxycode.reload.ru",
        "title": "%cmd.reload.title.ru%",
        "category": "FoxxyCode",
        "icon": "$(sync)"
      },
      {
        "command": "foxxycode.openInBrowser",
        "title": "%cmd.openInBrowser.title%",
        "category": "FoxxyCode",
        "icon": "$(link-external)"
      },
      {
        "command": "foxxycode.openInBrowser.ru",
        "title": "%cmd.openInBrowser.title.ru%",
        "category": "FoxxyCode",
        "icon": "$(link-external)"
      },
      {
        "command": "foxxycode.openDevtools",
        "title": "%cmd.openDevtools.title%",
        "category": "FoxxyCode",
        "icon": "$(tools)"
      },
      {
        "command": "foxxycode.openDevtools.ru",
        "title": "%cmd.openDevtools.title.ru%",
        "category": "FoxxyCode",
        "icon": "$(tools)"
      },
      {
        "command": "foxxycode.openSettings",
        "title": "%cmd.settings.title%",
        "category": "FoxxyCode",
        "icon": "$(gear)"
      },
      {
        "command": "foxxycode.openSettings.ru",
        "title": "%cmd.settings.title.ru%",
        "category": "FoxxyCode",
        "icon": "$(gear)"
      },
      {
        "command": "foxxycode.showLogs",
        "title": "%cmd.showLogs.title%",
        "category": "FoxxyCode",
        "icon": "$(output)"
      },
      {
        "command": "foxxycode.showLogs.ru",
        "title": "%cmd.showLogs.title.ru%",
        "category": "FoxxyCode",
        "icon": "$(output)"
      },
      {
        "command": "foxxycode.showWelcome",
        "title": "%cmd.showWelcome.title%",
        "category": "FoxxyCode",
        "icon": "$(question)"
      },
      {
        "command": "foxxycode.showWelcome.ru",
        "title": "%cmd.showWelcome.title.ru%",
        "category": "FoxxyCode",
        "icon": "$(question)"
      }
    ],
    "walkthroughs": [
      {
        "id": "foxxycode.welcome",
        "title": "%walkthrough.welcome.title%",
        "description": "%walkthrough.welcome.description%",
        "steps": [
          {
            "id": "openPanel",
            "title": "%walkthrough.step.openPanel.title%",
            "description": "%walkthrough.step.openPanel.description%",
            "media": {
              "markdown": "media/walkthrough/01-open-panel.md"
            },
            "completionEvents": [
              "onCommand:foxxycode.openPanel"
            ]
          },
          {
            "id": "apiKey",
            "title": "%walkthrough.step.apiKey.title%",
            "description": "%walkthrough.step.apiKey.description%",
            "media": {
              "markdown": "media/walkthrough/02-api-key.md"
            },
            "completionEvents": [
              "onCommand:foxxycode.openSettings"
            ]
          },
          {
            "id": "firstMessage",
            "title": "%walkthrough.step.firstMessage.title%",
            "description": "%walkthrough.step.firstMessage.description%",
            "media": {
              "markdown": "media/walkthrough/03-first-message.md"
            }
          },
          {
            "id": "reviewEdits",
            "title": "%walkthrough.step.reviewEdits.title%",
            "description": "%walkthrough.step.reviewEdits.description%",
            "media": {
              "markdown": "media/walkthrough/04-review-edits.md"
            }
          },
          {
            "id": "toolbar",
            "title": "%walkthrough.step.toolbar.title%",
            "description": "%walkthrough.step.toolbar.description%",
            "media": {
              "markdown": "media/walkthrough/05-toolbar.md"
            }
          }
        ]
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "foxxycode",
          "title": "%view.container.title%",
          "icon": "media/foxxycode.svg"
        }
      ]
    },
    "views": {
      "foxxycode": [
        {
          "id": "foxxycode.view",
          "name": "%view.name%",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "commandPalette": [
        {
          "command": "foxxycode.openPanel",
          "when": "foxxycode.locale == 'en'"
        },
        {
          "command": "foxxycode.openPanel.ru",
          "when": "foxxycode.locale == 'ru'"
        },
        {
          "command": "foxxycode.restart",
          "when": "foxxycode.locale == 'en'"
        },
        {
          "command": "foxxycode.restart.ru",
          "when": "foxxycode.locale == 'ru'"
        },
        {
          "command": "foxxycode.reload",
          "when": "foxxycode.locale == 'en'"
        },
        {
          "command": "foxxycode.reload.ru",
          "when": "foxxycode.locale == 'ru'"
        },
        {
          "command": "foxxycode.openInBrowser",
          "when": "foxxycode.locale == 'en'"
        },
        {
          "command": "foxxycode.openInBrowser.ru",
          "when": "foxxycode.locale == 'ru'"
        },
        {
          "command": "foxxycode.openDevtools",
          "when": "foxxycode.locale == 'en'"
        },
        {
          "command": "foxxycode.openDevtools.ru",
          "when": "foxxycode.locale == 'ru'"
        },
        {
          "command": "foxxycode.openSettings",
          "when": "foxxycode.locale == 'en'"
        },
        {
          "command": "foxxycode.openSettings.ru",
          "when": "foxxycode.locale == 'ru'"
        },
        {
          "command": "foxxycode.showLogs",
          "when": "foxxycode.locale == 'en'"
        },
        {
          "command": "foxxycode.showLogs.ru",
          "when": "foxxycode.locale == 'ru'"
        },
        {
          "command": "foxxycode.showWelcome",
          "when": "foxxycode.locale == 'en'"
        },
        {
          "command": "foxxycode.showWelcome.ru",
          "when": "foxxycode.locale == 'ru'"
        }
      ],
      "view/title": [
        {
          "command": "foxxycode.restart",
          "when": "view == foxxycode.view && foxxycode.locale == 'en'",
          "group": "navigation@1"
        },
        {
          "command": "foxxycode.restart.ru",
          "when": "view == foxxycode.view && foxxycode.locale == 'ru'",
          "group": "navigation@1"
        },
        {
          "command": "foxxycode.reload",
          "when": "view == foxxycode.view && foxxycode.locale == 'en'",
          "group": "navigation@2"
        },
        {
          "command": "foxxycode.reload.ru",
          "when": "view == foxxycode.view && foxxycode.locale == 'ru'",
          "group": "navigation@2"
        },
        {
          "command": "foxxycode.openInBrowser",
          "when": "view == foxxycode.view && foxxycode.locale == 'en'",
          "group": "navigation@3"
        },
        {
          "command": "foxxycode.openInBrowser.ru",
          "when": "view == foxxycode.view && foxxycode.locale == 'ru'",
          "group": "navigation@3"
        },
        {
          "command": "foxxycode.openDevtools",
          "when": "view == foxxycode.view && foxxycode.locale == 'en'",
          "group": "navigation@4"
        },
        {
          "command": "foxxycode.openDevtools.ru",
          "when": "view == foxxycode.view && foxxycode.locale == 'ru'",
          "group": "navigation@4"
        },
        {
          "command": "foxxycode.openSettings",
          "when": "view == foxxycode.view && foxxycode.locale == 'en'",
          "group": "navigation@5"
        },
        {
          "command": "foxxycode.openSettings.ru",
          "when": "view == foxxycode.view && foxxycode.locale == 'ru'",
          "group": "navigation@5"
        },
        {
          "command": "foxxycode.showLogs",
          "when": "view == foxxycode.view && foxxycode.locale == 'en'",
          "group": "navigation@6"
        },
        {
          "command": "foxxycode.showLogs.ru",
          "when": "view == foxxycode.view && foxxycode.locale == 'ru'",
          "group": "navigation@6"
        }
      ],
      "webview/title": [
        {
          "command": "foxxycode.restart",
          "when": "foxxycode.editorPanelActive && foxxycode.locale == 'en'",
          "group": "navigation@1"
        },
        {
          "command": "foxxycode.restart.ru",
          "when": "foxxycode.editorPanelActive && foxxycode.locale == 'ru'",
          "group": "navigation@1"
        },
        {
          "command": "foxxycode.reload",
          "when": "foxxycode.editorPanelActive && foxxycode.locale == 'en'",
          "group": "navigation@2"
        },
        {
          "command": "foxxycode.reload.ru",
          "when": "foxxycode.editorPanelActive && foxxycode.locale == 'ru'",
          "group": "navigation@2"
        },
        {
          "command": "foxxycode.openInBrowser",
          "when": "foxxycode.editorPanelActive && foxxycode.locale == 'en'",
          "group": "navigation@3"
        },
        {
          "command": "foxxycode.openInBrowser.ru",
          "when": "foxxycode.editorPanelActive && foxxycode.locale == 'ru'",
          "group": "navigation@3"
        },
        {
          "command": "foxxycode.openDevtools",
          "when": "foxxycode.editorPanelActive && foxxycode.locale == 'en'",
          "group": "navigation@4"
        },
        {
          "command": "foxxycode.openDevtools.ru",
          "when": "foxxycode.editorPanelActive && foxxycode.locale == 'ru'",
          "group": "navigation@4"
        },
        {
          "command": "foxxycode.openSettings",
          "when": "foxxycode.editorPanelActive && foxxycode.locale == 'en'",
          "group": "navigation@5"
        },
        {
          "command": "foxxycode.openSettings.ru",
          "when": "foxxycode.editorPanelActive && foxxycode.locale == 'ru'",
          "group": "navigation@5"
        }
      ]
    },
    "configuration": {
      "title": "%cfg.title%",
      "properties": {
        "foxxycode.binaryPath": {
          "type": "string",
          "default": "",
          "description": "%cfg.binaryPath.description%"
        },
        "foxxycode.host": {
          "type": "string",
          "default": "127.0.0.1",
          "description": "%cfg.host.description%"
        },
        "foxxycode.port": {
          "type": "number",
          "default": 0,
          "description": "%cfg.port.description%"
        },
        "foxxycode.home": {
          "type": "string",
          "default": "",
          "description": "%cfg.home.description%"
        },
        "foxxycode.extraArgs": {
          "type": "string",
          "default": "",
          "description": "%cfg.extraArgs.description%"
        },
        "foxxycode.followVscodeTheme": {
          "type": "boolean",
          "default": true,
          "description": "%cfg.followVscodeTheme.description%"
        },
        "foxxycode.nativeDiffs": {
          "type": "boolean",
          "default": true,
          "description": "%cfg.nativeDiffs.description%"
        },
        "foxxycode.autoApproveEdits": {
          "type": "boolean",
          "default": false,
          "description": "%cfg.autoApproveEdits.description%"
        },
        "foxxycode.trackOpenFiles": {
          "type": "boolean",
          "default": true,
          "description": "%cfg.trackOpenFiles.description%"
        },
        "foxxycode.trackTerminals": {
          "type": "boolean",
          "default": true,
          "description": "%cfg.trackTerminals.description%"
        }
      }
    }
  },
  "scripts": {
    "prepare-binary": "node scripts/prepare-binary.mjs",
    "prepare-binary:target": "node scripts/prepare-binary.mjs --target",
    "compile": "esbuild src/extension.ts --bundle --platform=node --format=cjs --external:vscode --outfile=out/extension.js --sourcemap",
    "build": "npm run prepare-binary && npm run compile",
    "build:target": "node scripts/prepare-binary.mjs --target",
    "package": "npm run prepare-binary && npm run compile && vsce package",
    "package:universal": "npm run prepare-binary && npm run compile && vsce package -o foxxycode-vscode-%npm_package_version%.vsix",
    "package:target": "npm run build:target && npm run compile && vsce package --target %npm_config_vsce_target% -o foxxycode-vscode-%npm_config_vsce_target%-%npm_package_version%.vsix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "diff": "^5.2.0",
    "foxxycode-vscode": "file:"
  },
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.75.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.23.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
