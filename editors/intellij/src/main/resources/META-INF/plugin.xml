<idea-plugin>
    <id>dev.foxxycode.intellij</id>
    <name>FoxxyCode</name>
    <vendor email="hebopine981@gmail.com">FoxxyCode</vendor>

    <description><![CDATA[
        <p>Run the full <b>FoxxyCode</b> agent inside any JetBrains IDE (IntelliJ IDEA, PhpStorm,
        WebStorm, PyCharm, GoLand, etc.).</p>
        <p>The plugin launches the <code>foxxycode http</code> process scoped to the current project
        and embeds the complete FoxxyCode web UI in a tool window via JCEF: chat, sessions/history,
        scheduler, settings (API keys), skills browser, plan mode, model &amp; reasoning selection,
        and memory.</p>
        <p>The <code>foxxycode</code> binary is built from source and bundled with the plugin — no
        download step. You can point the plugin at a custom <code>foxxycode</code> binary in
        Settings | Tools | FoxxyCode.</p>
    ]]></description>

    <!-- Platform-only dependency: installs in every IntelliJ-based IDE. -->
    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <applicationService serviceImplementation="dev.foxxycode.intellij.settings.FoxxyCodeSettings"/>
        <projectService serviceImplementation="dev.foxxycode.intellij.process.FoxxyCodeProcessManager"/>
        <projectService serviceImplementation="dev.foxxycode.intellij.diff.FoxxyCodeIdeDiffService"/>
        <projectService serviceImplementation="dev.foxxycode.intellij.editor.FoxxyCodeEditorContextService"/>
        <projectService serviceImplementation="dev.foxxycode.intellij.terminal.FoxxyCodeTerminalContextService"/>

        <applicationConfigurable
                parentId="tools"
                id="dev.foxxycode.intellij.settings.FoxxyCodeConfigurable"
                displayName="FoxxyCode"
                instance="dev.foxxycode.intellij.settings.FoxxyCodeConfigurable"/>

        <toolWindow
                id="FoxxyCode"
                anchor="right"
                icon="/icons/foxxycodeToolWindow.svg"
                factoryClass="dev.foxxycode.intellij.ui.FoxxyCodeToolWindowFactory"/>

        <notificationGroup id="FoxxyCode" displayType="BALLOON"/>
    </extensions>

    <actions>
        <action id="FoxxyCodeWelcome"
                class="dev.foxxycode.intellij.ui.FoxxyCodeWelcomeAction"
                text="Show FoxxyCode Welcome"
                description="Re-open the FoxxyCode onboarding tour">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
